# Oz — Environment Configuration
# Copy this to .env and customize before running docker compose up

# LLM Model for LEON (local via llama.cpp)
LLAMA_MODEL=qwen2.5-1.5b-instruct-q4_k_m.gguf
LLAMA_MODEL_URL=https://huggingface.co/Qwen/Qwen2.5-1.5B-Instruct-GGUF/resolve/main/qwen2.5-1.5b-instruct-q4_k_m.gguf
LLAMA_CTX_SIZE=4096

# Ports
OZ_WEB_PORT=3000
OZ_API_PORT=8000
LEON_PORT=5366
LLAMA_PORT=8080

# Database
POSTGRES_USER=oz
POSTGRES_PASSWORD=oz
POSTGRES_DB=oz

# Security (change in production!)
SECRET_KEY=change-me-in-production

# LEON Settings
LEON_LANG=en-US
LEON_TIME_ZONE=UTC
